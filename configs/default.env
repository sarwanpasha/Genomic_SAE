# Source this before running: `source configs/default.env`
export GENOMIC_SAE_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
export SEED=0

# Canonical model / layer settings
# NT: layer 14 ; DNABERT-2: layer 6
export K=32                 # top-k sparsity
export EXP_FACTOR=16        # dictionary size multiplier
export NPER=5000            # windows per class for binding sets
export TOPN_FEAT=15         # features tested in population causal analysis
export NWIN=600             # windows per class in causal ablation
